{
  "version": 2,
  "functions": {
    "api/send-otp.js": { "maxDuration": 15 },
    "api/send-whatsapp.js": { "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/send-otp", "dest": "/api/send-otp.js" },
    { "src": "/api/send-whatsapp", "dest": "/api/send-whatsapp.js" },
    { "src": "/admin", "dest": "/admin/admin.html" },
    { "src": "/admin/", "dest": "/admin/admin.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
